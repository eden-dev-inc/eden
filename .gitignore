# Generated by Cargo
# will have compiled files and executables
**/debug
**/target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

.DS_Create

**/.DS_Create
**/.DS_Store

# We don't need the test data
**/test.txt

.vscode
.idea
.ssh
.serena
**/*.swp
**/*.swo

frontend/www/node_modules
frontend/www/dist
eden_dashboard/dist/

datadog-api-key*
.env
*.env
!benchmark/configs/*.env

# Benchmark results (generated, may contain large perf.data and binaries)
benchmark/results/
eden_core/fast-telemetry/bench/results/

.env.*
!.env.example

# Snapshots
*.metadata.json
*.dump

# Python bytecode caches (e.g., from local-demo scripts)
**/__pycache__/
*.pyc

# Proptest regression files
**/proptest-regressions/

# Local config and test artifacts
eden.toml
notes/

# Local Claude Code allowlist; contains per-developer creds in command patterns
.claude/settings.json
# Local-only runtime state from the Claude CLI
.claude/scheduled_tasks.lock
.claude/worktrees/
# Local IDE/debug config with machine-specific paths (e.g. trunk runtimeExecutable)
.claude/launch.json
.artifacts/
.codex

# Python build artifacts for the Datadog integration
integrations/eden/dist/
integrations/eden/build/
integrations/eden/*.egg-info/

