# ADAM Demo — External Service Configuration
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ── Industry Vertical ──
# Options: retail, stonebreaker, finance, healthcare, insurance, tech, migration, bird
VERTICAL=retail

# BIRD benchmark database to import when VERTICAL=bird
BIRD_DB_ID=california_schools

# Stonebreaker document corpus (optional overrides)
# STONEBREAKER_DOC_DATASET=G4KMU/t2-ragbench
# STONEBREAKER_DOC_SUBSET=ConvFinQA
# STONEBREAKER_DOC_SPLIT=turn_0
# STONEBREAKER_DOC_LIMIT=250
# Optional: register the raw Stonebreaker corpus as a localfs endpoint.
# Data-init materializes markdown files under init/data/stonebreaker/localfs.
# Set this to the path as seen by your Eden process, for example:
# STONEBREAKER_LOCALFS_ROOT=/absolute/path/to/examples/adam-demo/init/data/stonebreaker/localfs

# ── External Services (optional, for ADAM endpoint registration) ──

# Tavily API key for web search (https://tavily.com)
TAVILY_API_KEY=tvly-your-api-key-here

# Google Workspace OAuth credentials
GOOGLE_WORKSPACE_CLIENT_ID=your-google-workspace-client-id
GOOGLE_WORKSPACE_PROJECT_ID=your-google-workspace-project-id
GOOGLE_WORKSPACE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_WORKSPACE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_WORKSPACE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_WORKSPACE_CLIENT_SECRET=your-google-workspace-client-secret
GOOGLE_WORKSPACE_ACCESS_TOKEN=your-google-workspace-access-token
GOOGLE_WORKSPACE_API_BASE_URL=https://www.googleapis.com

# OpenRouter API key and model (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# OpenAI API key and model (https://platform.openai.com/)
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-5.4-nano

# Datadog API keys (https://app.datadoghq.com/organization-settings/api-keys)
DD_API_KEY=your-datadog-api-key-here
DD_APP_KEY=your-datadog-app-key-here
DD_SITE=datadoghq.com

# Eraser API key for diagram generation (https://app.eraser.io)
ERASER_API_KEY=your-eraser-api-key-here

# ── Eden API (defaults work for local development) ──
# EDEN_API_URL=http://localhost:8000
# EDEN_ORG_ID=adam-demo
# EDEN_NEW_ORG_SECRET=neworgsecret

# ── Resilience (defaults are usually fine) ──
# HTTP_TIMEOUT=30
# SETUP_RETRIES=5
